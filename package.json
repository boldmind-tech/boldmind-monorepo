{
  "name": "boldmind-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=./apps/*",
    "dev:all": "concurrently \"pnpm dev:boldmind-hub\" \"pnpm dev:amebogist\" \"pnpm dev:planai-receptionist\" \"pnpm dev:educenter\" \"pnpm dev:boldmind-os\" \"pnpm dev:naija-fither\" \"pnpm dev:emailscraper\" \"pnpm dev:safe-ai\" \"pnpm dev:planai-social\" \"pnpm dev:planai-credibility\" \"pnpm dev:planai-business\" \"pnpm dev:planai-financial\" \"pnpm dev:planai-investor\" \"pnpm dev:planai-branding\" \"pnpm dev:planai-storefronts\" \"pnpm dev:planai-marketing\" \"pnpm dev:planai-analytics\" \"pnpm dev:afrohustle\" \"pnpm dev:naijagig\" \"pnpm dev:koloai\" \"pnpm dev:borderless\" \"pnpm dev:receipt\" \"pnpm dev:power\" \"pnpm dev:farmgate\" \"pnpm dev:afrocopy\" \"pnpm dev:skill2cash\" \"pnpm dev:anontruth\"",
    "dev:boldmind-hub": "cd apps/web/boldmind-hub && next dev -p 3000",
    "dev:amebogist": "cd apps/web/amebogist && next dev -p 3001",
    "dev:educenter": "cd apps/web/educenter && next dev -p 3002",
    "dev:boldmind-os": "cd apps/web/boldmind-os && next dev -p 3003",
    "dev:naija-fither": "cd apps/web/naija-fither && next dev -p 3004",
    "dev:emailscraper": "cd apps/web/emailscraper-pro && next dev -p 3005",
    "dev:safe-ai": "cd apps/web/safe-naija && next dev -p 3006",
    "dev:planai-receptionist": "cd apps/planai/receptionist && next dev -p 3007",
    "dev:planai-social": "cd apps/planai/social-factory && next dev -p 3008",
    "dev:planai-credibility": "cd apps/planai/credibility-hubs && next dev -p 3009",
    "dev:planai-business": "cd apps/planai/business-planning && next dev -p 3010",
    "dev:planai-financial": "cd apps/planai/financial-forecasting && next dev -p 3011",
    "dev:planai-investor": "cd apps/planai/investor-readiness && next dev -p 3012",
    "dev:planai-branding": "cd apps/planai/branding-design && next dev -p 3013",
    "dev:planai-storefronts": "cd apps/planai/digital-storefronts && next dev -p 3014",
    "dev:planai-marketing": "cd apps/planai/marketing-automation && next dev -p 3015",
    "dev:planai-analytics": "cd apps/planai/analytics-dashboard && next dev -p 3016",
    "dev:afrohustle": "cd apps/web/afrohustle-os && next dev -p 3017",
    "dev:naijagig": "cd apps/web/naijagig-matcher && next dev -p 3018",
    "dev:koloai": "cd apps/web/kolo-ai && next dev -p 3019",
    "dev:borderless": "cd apps/web/borderless-remit && next dev -p 3020",
    "dev:receipt": "cd apps/web/receipt-genius && next dev -p 3021",
    "dev:power": "cd apps/web/power-alert && next dev -p 3022",
    "dev:farmgate": "cd apps/web/farmgate-direct && next dev -p 3023",
    "dev:afrocopy": "cd apps/web/afrocopy-ai && next dev -p 3024",
    "dev:skill2cash": "cd apps/web/skill2cash && next dev -p 3025",
    "dev:anontruth": "cd apps/web/anontruth-mic && next dev -p 3026",
    "build": "turbo run build",
    "build:boldmind-hub": "cd apps/web/boldmind-hub && next build",
    "build:amebogist": "cd apps/web/amebogist && next build",
    "build:educenter": "cd apps/web/educenter && next build",
    "build:boldmind-os": "cd apps/web/boldmind-os && next build",
    "build:naija-fither": "cd apps/web/naija-fither && next build",
    "build:emailscraper": "cd apps/web/emailscraper-pro && next build",
    "build:safe-ai": "cd apps/web/safe-naija && next build",
    "build:planai": "turbo run build --filter=./apps/planai/*",
    "build:shared": "turbo run build --filter=@boldmind/ui --filter=@boldmind/utils --filter=@boldmind/api-client --filter=@boldmind/database --filter=@boldmind/auth --filter=@boldmind/payments --filter=@boldmind/ai",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "start:all": "concurrently \"pnpm start:boldmind-hub\" \"pnpm start:amebogist\" \"pnpm start:planai-receptionist\"",
    "start:boldmind-hub": "cd apps/web/boldmind-hub && next start -p 3000",
    "start:amebogist": "cd apps/web/amebogist && next start -p 3001",
    "start:educenter": "cd apps/web/educenter && next start -p 3002",
    "start:planai-receptionist": "cd apps/planai/receptionist && next start -p 3007",
    "build:groups": "turbo run build --parallel --continue",
    "build:web": "turbo run build --filter=./apps/web/*",
    "build:selected": "turbo run build --filter=@boldmind/boldmind-hub --filter=@boldmind/amebogist --filter=@boldmind/educenter --filter=@boldmind/receptionist",
    "dev:selected": "concurrently \"pnpm dev:boldmind-hub\" \"pnpm dev:amebogist\" \"pnpm dev:educenter\" \"pnpm dev:planai-receptionist\"",
    "setup": "pnpm install && pnpm build:shared && echo \"✅ Setup complete!\"",
    "reset": "pnpm clean && rm -rf node_modules && pnpm install && pnpm build:shared"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vercel/ncc": "^0.38.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^1.0.0",
    "@prisma/client": "^5.7.0",
    "@tanstack/react-query": "^5.0.0",
    "@types/pg": "^8.16.0",
    "autoprefixer": "^10.4.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "0.562.0",
    "mongodb": "^6.0.0",
    "mongoose": "^8.0.0",
    "next": "^14.0.0",
    "next-auth": "^4.24.0",
    "pg": "^8.16.3",
    "postcss": "^8.4.0",
    "prisma": "^5.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.0.0",
    "react-hot-toast": "^2.4.0",
    "recharts": "^2.10.0",
    "sharp": "^0.33.0",
    "supabase": "^2.39.0",
    "tailwindcss": "^3.3.0",
    "zod": "^3.22.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}